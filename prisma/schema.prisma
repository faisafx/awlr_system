// ─────────────────────────────────────────────────────────────────────────────
// File: prisma/schema.prisma
// Architecture: Enterprise-Grade Relational Schema for AWLR Command Center
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

generator client {
  provider = "prisma-client-js"
}

// 🗺️ 1. TABEL REGISTRI STASIUN / TITIK POS AWLR
model StationNode {
  id          String   @id // Contoh: "WGG-01"
  name        String   // Contoh: "Pos AWLR Jembatan Wanggu"
  latitude    Float    
  longitude   Float    
  location    String   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Hubungan Relasional (One-to-Many)
  telemetryLogs  TelemetryLog[]
  hardwareAssets HardwareAsset[]
}

// 📡 2. TABEL TELEMETRI DATA SENSOR (Wide Table Pattern untuk Time-Series)
model TelemetryLog {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  
  // Relasi ke tabel StationNode
  nodeId         String
  station        StationNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  
  // WIDE TABLE PATTERN: Semua data difusikan dalam satu baris waktu
  tmaUltrasonic  Float?
  tmaHydrostatic Float?
  curahHujan     Float?
  flowRate1      Float?
  flowRate2      Float?
  velocity       Float?
  discharge      Float?
  
  // Aktuator & Status EWS
  relay1Siren    Boolean  @default(false)
  relay2Alarm    Boolean  @default(false)
  ewsStatus      WaterStatus @default(AMAN)

  // ⚡ COMPOSITE INDEXING: Kunci kecepatan loading grafik Apache ECharts!
  @@index([nodeId, timestamp(sort: Desc)])
  @@index([timestamp])
}

// ⚙️ 3. TABEL HARDWARE REGISTRY & INTEGRITY (BMN Audit & Health Monitor)
model HardwareAsset {
  assetCode          String     @id 
  componentName      String     
  modelNumber        String     
  installationDate   DateTime   @default(now())
  operatingHours     Int        @default(0)  
  healthIndex        Int        @default(100) 
  calibrationDueDays Int        // Diganti dari nextCalibration agar sesuai dengan interface API TypeScript Anda
  technician         String     
  criticality        AssetLevel @default(MEDIUM) 
  isActive           Boolean    @default(true)
  
  // Relasi penempatan instrumen pada stasiun tertentu
  nodeId             String
  station            StationNode @relation(fields: [nodeId], references: [id], onDelete: Restrict)
}

// 📑 POSTGRES ENUMS
enum WaterStatus {
  AMAN
  WASPADA
  SIAGA
  AWAS
}

enum AssetLevel {
  HIGH
  MEDIUM
  LOW
}